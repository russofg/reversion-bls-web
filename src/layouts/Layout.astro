---
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const siteUrl = "https://reversionbls.netlify.app";
const ogImage = `${siteUrl}/og-image.png`;
const logoImage = `${siteUrl}/favicon.png`;

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      url: siteUrl,
      name: "BLS Servicios Audiovisuales",
      description:
        "Soluciones audiovisuales profesionales para eventos corporativos en Argentina",
      inLanguage: "es-AR",
    },
    {
      "@type": "LocalBusiness",
      "@id": `${siteUrl}/#organization`,
      name: "BLS Servicios Audiovisuales",
      url: siteUrl,
      description:
        "Empresa líder en soluciones audiovisuales para eventos corporativos en Argentina. Alquiler de sonido profesional, iluminación, pantallas LED y producción técnica integral.",
      telephone: "+541151834646",
      email: "info@blsnet.com.ar",
      address: {
        "@type": "PostalAddress",
        streetAddress: "Catamarca 809",
        addressLocality: "Buenos Aires",
        addressRegion: "CABA",
        postalCode: "C1231ABK",
        addressCountry: "AR",
      },
      geo: {
        "@type": "GeoCoordinates",
        latitude: -34.608936,
        longitude: -58.414487,
      },
      openingHoursSpecification: {
        "@type": "OpeningHoursSpecification",
        dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
        opens: "09:00",
        closes: "17:00",
      },
      priceRange: "$$$",
      image: ogImage,
      logo: logoImage,
      hasOfferCatalog: {
        name: "BLS Servicios Audiovisuales",
        itemListElement: [
          {
            "@type": "Offer",
            itemOffered: {
              "@type": "Service",
              name: "Sonido Profesional",
              description:
                "Sistemas de line array de última generación y microfonía premium para eventos.",
            },
          },
          {
            "@type": "Offer",
            itemOffered: {
              "@type": "Service",
              name: "Iluminación Profesional",
              description:
                "Diseño de ambientes y efectos con cabezas móviles y tecnología LED.",
            },
          },
          {
            "@type": "Offer",
            itemOffered: {
              "@type": "Service",
              name: "Video y Proyección",
              description:
                "Pantallas LED de alta resolución, mapping y streaming profesional.",
            },
          },
        ],
      },
      areaServed: {
        "@type": "Country",
        name: "Argentina",
      },
      knowsAbout: [
        "Producción audiovisual para eventos",
        "Alquiler de sonido profesional",
        "Iluminación escénica",
        "Pantallas LED para eventos",
        "Streaming profesional",
        "Eventos corporativos",
        "Producción técnica integral",
      ],
    },
  ],
};

import "@fontsource-variable/jost";
import "@fontsource-variable/cabin";
import { ClientRouter } from "astro:transitions";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <ClientRouter />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, viewport-fit=cover"
    />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#020408" />
    <meta name="color-scheme" content="dark" />
    <meta name="author" content="BLS Servicios Audiovisuales" />
    <meta
      name="keywords"
      content="audiovisual, eventos corporativos, sonido profesional, iluminación, pantallas LED, streaming, producción técnica, alquiler equipos audiovisuales, Buenos Aires, Argentina, BLS"
    />
    <meta
      name="robots"
      content="index, follow, max-image-preview:large, max-snippet:-1"
    />

    <link rel="canonical" href={siteUrl} />
    <link rel="alternate" hreflang="es" href={siteUrl} />
    <link rel="alternate" hreflang="x-default" href={siteUrl} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="es_AR" />
    <meta property="og:site_name" content="BLS Audiovisual" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="shortcut icon" href="/favicon.png" />
    <link rel="dns-prefetch" href="https://www.google.com" />
    <link rel="preconnect" href="https://www.google.com" crossorigin />
    <link rel="sitemap" href="/sitemap.xml" />

    <title>{title}</title>

    <Fragment
      set:html={`<script type="application/ld+json">${JSON.stringify(structuredData)}</script>`}
    />

    <style is:global>
      @import "@/styles/global.css";
    </style>
  </head>
  <body class="min-h-svh">
    <div class="noise-overlay" aria-hidden="true"></div>
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-200 focus:bg-neon-blue focus:text-glitch-black focus:px-4 focus:py-2 focus:font-bold focus:rounded"
    >
      Saltar al contenido
    </a>
    <slot />

    <!-- WhatsApp FAB -->
    <a
      href="https://wa.me/541151834646?text=Hola%20BLS%2C%20me%20gustaría%20consultar%20sobre%20sus%20servicios%20audiovisuales."
      target="_blank"
      rel="noopener noreferrer"
      class="fixed bottom-6 right-6 z-400 flex items-center gap-3 group"
      aria-label="Contactar por WhatsApp"
    >
      <!-- Tooltip -->
      <span
        class="opacity-0 group-hover:opacity-100 transition-all duration-300 translate-x-2 group-hover:translate-x-0 bg-glitch-black border border-white/10 text-white text-xs font-black uppercase tracking-widest px-4 py-2 whitespace-nowrap pointer-events-none"
      >
        Escribinos
      </span>
      <!-- Botón -->
      <div
        class="w-14 h-14 bg-[#25D366] hover:bg-[#1ebe5d] transition-all duration-300 rounded-full flex items-center justify-center shadow-[0_0_20px_rgba(37,211,102,0.4)] hover:shadow-[0_0_30px_rgba(37,211,102,0.7)] hover:scale-110 active:scale-95"
      >
        <svg
          class="w-7 h-7"
          viewBox="0 0 24 24"
          fill="white"
          aria-hidden="true"
        >
          <path
            d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
          ></path>
        </svg>
      </div>
    </a>

    <!-- Scroll Progress Bar -->
    <div
      class="fixed top-0 left-0 h-[3px] bg-neon-lime z-500 origin-left"
      style="transform: scaleX(0); transition: transform 0.15s linear;"
      data-scroll-progress
      aria-hidden="true"
    ></div>

    <!-- Back to Top Button -->
    <button
      class="fixed bottom-24 right-6 z-400 w-12 h-12 bg-glitch-black/80 backdrop-blur-md border border-white/10 text-white/60 hover:text-neon-lime hover:border-neon-lime flex items-center justify-center rounded-full opacity-0 pointer-events-none transition-all duration-300 hover:scale-110 active:scale-95"
      style="transform: translateY(20px);"
      data-back-to-top
      aria-label="Volver arriba"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 15.75l7.5-7.5 7.5 7.5" />
      </svg>
    </button>

    <!-- Custom Cursor (desktop only) -->
    <div
      class="fixed top-0 left-0 w-5 h-5 rounded-full border-2 border-neon-lime pointer-events-none z-9999 mix-blend-difference hidden md:block"
      style="transform: translate(-50%, -50%); transition: width 0.3s, height 0.3s, opacity 0.3s;"
      data-cursor-dot
      aria-hidden="true"
    ></div>
    <div
      class="fixed top-0 left-0 w-10 h-10 rounded-full border border-neon-blue/40 pointer-events-none z-9998 mix-blend-difference hidden md:block"
      style="transform: translate(-50%, -50%);"
      data-cursor-ring
      aria-hidden="true"
    ></div>

    <!-- Splash Screen -->
    <div
      class="fixed inset-0 z-10000 bg-glitch-black flex items-center justify-center"
      data-splash
      aria-hidden="true"
    >
      <div class="text-center" data-splash-content>
        <div class="relative inline-block mb-4">
          <img
            src="/favicon.png"
            alt=""
            class="w-20 h-20 sm:w-24 sm:h-24 object-contain"
            style="filter: invert(1) brightness(1.8);"
          />
        </div>
        <div class="overflow-hidden">
          <p class="font-headline font-black text-xl sm:text-2xl text-white tracking-[0.3em] uppercase translate-y-full" data-splash-text>
            BLS Audiovisual
          </p>
        </div>
        <div class="w-32 h-[2px] bg-white/10 mx-auto mt-6 overflow-hidden rounded-full">
          <div class="h-full bg-neon-lime origin-left" style="animation: splash-bar 1.6s ease-in-out forwards;" data-splash-bar></div>
        </div>
      </div>
    </div>

    <style>
      @keyframes splash-bar {
        0% { transform: scaleX(0); }
        100% { transform: scaleX(1); }
      }

      body.splash-active {
        overflow: hidden;
      }

      [data-cursor-dot], [data-cursor-ring] {
        will-change: transform;
      }
    </style>

    <script>
      import "@/scripts/smooth-scroll";
      import "@/scripts/animations";

      // --- Splash Screen ---
      const splash = document.querySelector<HTMLElement>("[data-splash]");
      const splashText = document.querySelector<HTMLElement>("[data-splash-text]");

      if (splash && !sessionStorage.getItem("bls-splash-shown")) {
        document.body.classList.add("splash-active");

        setTimeout(() => {
          if (splashText) {
            splashText.style.transition = "transform 0.8s cubic-bezier(0.16, 1, 0.3, 1)";
            splashText.style.transform = "translateY(0)";
          }
        }, 300);

        setTimeout(() => {
          splash.style.transition = "opacity 0.6s ease, transform 0.6s ease";
          splash.style.opacity = "0";
          splash.style.transform = "scale(1.05)";
          setTimeout(() => {
            splash.remove();
            document.body.classList.remove("splash-active");
          }, 600);
          sessionStorage.setItem("bls-splash-shown", "1");
        }, 2200);
      } else {
        splash?.remove();
      }

      // --- Scroll Progress Bar ---
      const progressBar = document.querySelector<HTMLElement>("[data-scroll-progress]");
      window.addEventListener("scroll", () => {
        if (!progressBar) return;
        const h = document.documentElement.scrollHeight - window.innerHeight;
        const progress = h > 0 ? window.scrollY / h : 0;
        progressBar.style.transform = `scaleX(${Math.min(progress, 1)})`;
      }, { passive: true });

      // --- Back to Top ---
      const backBtn = document.querySelector<HTMLButtonElement>("[data-back-to-top]");
      window.addEventListener("scroll", () => {
        if (!backBtn) return;
        if (window.scrollY > 600) {
          backBtn.style.opacity = "1";
          backBtn.style.pointerEvents = "auto";
          backBtn.style.transform = "translateY(0)";
        } else {
          backBtn.style.opacity = "0";
          backBtn.style.pointerEvents = "none";
          backBtn.style.transform = "translateY(20px)";
        }
      }, { passive: true });

      backBtn?.addEventListener("click", () => {
        window.scrollTo({ top: 0, behavior: "smooth" });
      });

      // --- Custom Cursor (desktop only) ---
      const dot = document.querySelector<HTMLElement>("[data-cursor-dot]");
      const ring = document.querySelector<HTMLElement>("[data-cursor-ring]");

      if (dot && ring && window.matchMedia("(pointer: fine)").matches) {
        let mx = 0, my = 0;
        let rx = 0, ry = 0;

        document.addEventListener("mousemove", (e) => {
          mx = e.clientX;
          my = e.clientY;
          dot.style.left = mx + "px";
          dot.style.top = my + "px";
        });

        function animateRing(): void {
          rx += (mx - rx) * 0.15;
          ry += (my - ry) * 0.15;
          ring!.style.left = rx + "px";
          ring!.style.top = ry + "px";
          requestAnimationFrame(animateRing);
        }
        animateRing();

        document.querySelectorAll("a, button, [data-magnetic]").forEach((el) => {
          el.addEventListener("mouseenter", () => {
            dot.style.width = "40px";
            dot.style.height = "40px";
            dot.style.borderColor = "var(--color-neon-fuchsia)";
            dot.style.opacity = "0.5";
            ring!.style.opacity = "0";
          });
          el.addEventListener("mouseleave", () => {
            dot.style.width = "20px";
            dot.style.height = "20px";
            dot.style.borderColor = "var(--color-neon-lime)";
            dot.style.opacity = "1";
            ring!.style.opacity = "1";
          });
        });

        document.documentElement.style.cursor = "none";
        document.querySelectorAll("a, button").forEach((el) => {
          (el as HTMLElement).style.cursor = "none";
        });
      } else {
        dot?.remove();
        ring?.remove();
      }
    </script>
  </body>
</html>
