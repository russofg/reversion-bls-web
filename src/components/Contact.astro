---
const contactInfo = [
  {
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"/></svg>`,
    text: "info@blsnet.com.ar",
    href: "mailto:info@blsnet.com.ar",
  },
  {
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"/></svg>`,
    text: "+54 11 5183-4646",
    href: "tel:+541151834646",
  },
  {
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/></svg>`,
    text: "Catamarca 809, CABA, Buenos Aires",
    href: "https://maps.google.com/?q=Catamarca+809+CABA+Buenos+Aires+Argentina",
  },
  {
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>`,
    text: "Lunes a Viernes: 9:00 - 17:00",
    href: null,
  },
];
---

<section class="relative py-20 sm:py-32 md:py-48 bg-glitch-black" id="contact">
  <div class="container mx-auto px-5 sm:px-6 max-w-7xl">
    <div class="relative">
      <div
        class="absolute -top-12 -left-12 w-64 h-64 bg-neon-blue/10 border border-neon-lime rotate-6 pointer-events-none hidden md:block"
        aria-hidden="true"
      >
      </div>
      <div
        class="absolute -bottom-12 -right-12 w-80 h-80 bg-neon-fuchsia/10 border border-neon-lime -rotate-3 pointer-events-none hidden md:block"
        aria-hidden="true"
      >
      </div>

      <div
        class="flex flex-col md:flex-row bg-glitch-black border border-white/10 relative z-10 shadow-[0_0_50px_rgba(0,0,0,1)]"
      >
        <div
          class="p-8 sm:p-10 md:p-16 md:w-5/12 bg-neon-lime text-black"
          data-contact-left
        >
          <h2
            class="text-3xl sm:text-4xl md:text-5xl font-headline font-black mb-6 sm:mb-8 leading-tight uppercase -skew-x-6"
          >
            Hablemos de tu próximo evento
          </h2>
          <p
            class="text-black/80 text-base sm:text-lg mb-8 sm:mb-10 font-bold italic"
          >
            Nuestro equipo Técnico está listo para asesorarte en cada detalle.
          </p>

          <address class="not-italic space-y-4 sm:space-y-5 mb-8 sm:mb-10">
            {
              contactInfo.map(({ icon, text, href }) => (
                <div class="flex items-center gap-4 sm:gap-5">
                  <span class="text-black shrink-0">
                    <Fragment set:html={icon} />
                  </span>
                  {href ? (
                    <a
                      href={href}
                      target={href.startsWith("http") ? "_blank" : undefined}
                      rel={
                        href.startsWith("http")
                          ? "noopener noreferrer"
                          : undefined
                      }
                      class="text-black font-black text-xs sm:text-sm tracking-widest border-b-2 border-black/20 hover:border-black transition-colors break-all sm:break-normal"
                    >
                      {text}
                    </a>
                  ) : (
                    <span class="text-black font-black text-xs sm:text-sm tracking-widest">
                      {text}
                    </span>
                  )}
                </div>
              ))
            }
          </address>

          <div class="overflow-hidden rounded border border-black/20">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3283.821271455183!2d-58.41448758477131!3d-34.60893678045779!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x95bcca8c854bd13f%3A0xfc0cf5c054f9e897!2sCatamarca%20809%2C%20C1231ABK%20CABA!5e0!3m2!1ses!2sar!4v1716576173567!5m2!1ses!2sar"
              width="100%"
              height="180"
              style="border:0; filter: grayscale(1) invert(1) contrast(1.2) hue-rotate(180deg);"
              allowfullscreen
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Ubicación de BLS Audiovisual en Catamarca 809, CABA"
            ></iframe>
          </div>
        </div>

        <div
          class="p-8 sm:p-10 md:p-16 md:w-7/12 bg-glitch-black"
          data-contact-right
        >
          <form
            class="space-y-8 sm:space-y-12"
            name="contacto"
            method="POST"
            data-netlify="true"
            netlify-honeypot="bot-field"
            data-contact-form
          >
            <input type="hidden" name="form-name" value="contacto" />
            <p class="hidden" aria-hidden="true">
              <label>No completar: <input name="bot-field" /></label>
            </p>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 sm:gap-12">
              <div>
                <label
                  for="contact-name"
                  class="block text-[11px] font-black uppercase tracking-[0.3em] text-neon-lime mb-3 sm:mb-4"
                >
                  Nombre Completo
                </label>
                <input
                  id="contact-name"
                  name="nombre"
                  type="text"
                  required
                  placeholder="Ej. Juan Pérez"
                  autocomplete="name"
                  class="w-full bg-transparent border-b-2 border-white/10 focus:border-neon-lime p-2 transition-all outline-none placeholder:text-white/20 text-white min-h-11"
                />
                <span class="text-red-400 text-xs mt-1 hidden" data-error="nombre">Ingresá tu nombre</span>
              </div>
              <div>
                <label
                  for="contact-email"
                  class="block text-[11px] font-black uppercase tracking-[0.3em] text-neon-lime mb-3 sm:mb-4"
                >
                  Email
                </label>
                <input
                  id="contact-email"
                  name="email"
                  type="email"
                  required
                  placeholder="juan@ejemplo.com"
                  autocomplete="email"
                  class="w-full bg-transparent border-b-2 border-white/10 focus:border-neon-lime p-2 transition-all outline-none placeholder:text-white/20 text-white min-h-11"
                />
                <span class="text-red-400 text-xs mt-1 hidden" data-error="email">Ingresá un email válido</span>
              </div>
            </div>
            <div>
              <label
                for="contact-message"
                class="block text-[11px] font-black uppercase tracking-[0.3em] text-neon-lime mb-3 sm:mb-4"
              >
                Mensaje
              </label>
              <textarea
                id="contact-message"
                name="mensaje"
                rows="4"
                required
                placeholder="Contanos sobre tu evento..."
                class="w-full bg-transparent border-b-2 border-white/10 focus:border-neon-blue p-2 transition-all outline-none placeholder:text-white/20 text-white resize-none min-h-[120px]"
              ></textarea>
              <span class="text-red-400 text-xs mt-1 hidden" data-error="mensaje">Escribí tu mensaje</span>
            </div>
            <button
              type="submit"
              class="w-full py-4 sm:py-6 bg-neon-lime text-black font-headline font-black text-lg sm:text-xl uppercase tracking-[0.2em] hover:scale-[1.02] active:scale-[0.98] transition-all relative overflow-hidden group min-h-14 disabled:opacity-50 disabled:cursor-not-allowed"
              data-magnetic
              data-submit-btn
            >
              <span class="relative z-10" data-submit-text>Enviar Mensaje</span>
              <div
                class="absolute inset-0 bg-white/20 -translate-x-full group-hover:translate-x-0 transition-transform duration-500"
              >
              </div>
            </button>

            <!-- Feedback messages -->
            <div class="hidden text-center py-6 px-4 border border-neon-lime/30 bg-neon-lime/5" data-form-success>
              <svg class="w-12 h-12 text-neon-lime mx-auto mb-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
              <p class="text-neon-lime font-headline font-black text-lg uppercase tracking-widest">¡Mensaje enviado!</p>
              <p class="text-white/60 text-sm mt-2">Nos pondremos en contacto pronto.</p>
            </div>

            <div class="hidden text-center py-6 px-4 border border-red-400/30 bg-red-400/5" data-form-error>
              <svg class="w-12 h-12 text-red-400 mx-auto mb-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z"/></svg>
              <p class="text-red-400 font-headline font-black text-lg uppercase tracking-widest">Error al enviar</p>
              <p class="text-white/60 text-sm mt-2">Intentá de nuevo o contactanos por WhatsApp.</p>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.querySelector<HTMLFormElement>("[data-contact-form]");
  const submitBtn = document.querySelector<HTMLButtonElement>("[data-submit-btn]");
  const submitText = document.querySelector<HTMLSpanElement>("[data-submit-text]");
  const successMsg = document.querySelector<HTMLElement>("[data-form-success]");
  const errorMsg = document.querySelector<HTMLElement>("[data-form-error]");

  function showError(name: string): void {
    const el = document.querySelector(`[data-error="${name}"]`);
    el?.classList.remove("hidden");
    el?.classList.add("block");
  }

  function clearErrors(): void {
    document.querySelectorAll("[data-error]").forEach((el) => {
      el.classList.add("hidden");
      el.classList.remove("block");
    });
  }

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    clearErrors();

    const data = new FormData(form);
    const nombre = (data.get("nombre") as string)?.trim();
    const email = (data.get("email") as string)?.trim();
    const mensaje = (data.get("mensaje") as string)?.trim();

    let valid = true;
    if (!nombre) { showError("nombre"); valid = false; }
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { showError("email"); valid = false; }
    if (!mensaje) { showError("mensaje"); valid = false; }
    if (!valid) return;

    if (submitBtn) submitBtn.disabled = true;
    if (submitText) submitText.textContent = "Enviando...";

    try {
      const res = await fetch("/", {
        method: "POST",
        headers: { "Content-Type": "application/x-www-form-urlencoded" },
        body: new URLSearchParams(data as unknown as Record<string, string>).toString(),
      });

      if (res.ok) {
        form.classList.add("hidden");
        successMsg?.classList.remove("hidden");
      } else {
        throw new Error("Network error");
      }
    } catch {
      errorMsg?.classList.remove("hidden");
    } finally {
      if (submitBtn) submitBtn.disabled = false;
      if (submitText) submitText.textContent = "Enviar Mensaje";
    }
  });
</script>
